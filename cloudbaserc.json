{
  "envId": "{{CLOUDBASE_ENV_ID}}",
  "functionRoot": "./cloudfunctions",
  "functions": [
    {
      "name": "exportAgendaPdf",
      "dir": "exportAgendaPdf",
      "handler": "index.main",
      "timeout": 60,
      "memorySize": 512,
      "installDependency": true
    }
  ],
  "framework": {
    "name": "ai-agenda-miniprogram",
    "plugins": {
      "client": {
        "use": "@cloudbase/framework-plugin-website",
        "inputs": {
          "outputPath": "miniprogram"
        }
      }
    }
  }
}
