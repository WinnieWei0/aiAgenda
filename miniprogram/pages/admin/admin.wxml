<view class="page">
  <view class="section panel">
    <view class="title">管理中心</view>
    <view class="button-row">
      <button size="mini" type="{{tab === 'memberships' ? 'primary' : 'default'}}" data-tab="memberships" bindtap="switchTab">Membership</button>
      <button size="mini" type="{{tab === 'pathways' ? 'primary' : 'default'}}" data-tab="pathways" bindtap="switchTab">Pathways</button>
      <button size="mini" type="{{tab === 'roles' ? 'primary' : 'default'}}" data-tab="roles" bindtap="switchTab">角色</button>
    </view>
    <button style="margin-top: 16rpx;" bindtap="seedWorkbookData">从 Excel 种子初始化</button>
  </view>

  <view class="section panel">
    <view class="title">编辑</view>
    <block wx:if="{{tab === 'memberships'}}">
      <input placeholder="中文名" value="{{draft.nameZh}}" data-field="nameZh" bindinput="handleDraftInput" />
      <input placeholder="英文名" value="{{draft.nameEn}}" data-field="nameEn" bindinput="handleDraftInput" />
      <input placeholder="昵称" value="{{draft.nickName}}" data-field="nickName" bindinput="handleDraftInput" />
      <input placeholder="中文议程显示名" value="{{draft.agendaNameZh}}" data-field="agendaNameZh" bindinput="handleDraftInput" />
      <input placeholder="英文议程显示名" value="{{draft.titleOnAgenda}}" data-field="titleOnAgenda" bindinput="handleDraftInput" />
      <input placeholder="电话" value="{{draft.phone}}" data-field="phone" bindinput="handleDraftInput" />
      <input placeholder="邮箱" value="{{draft.email}}" data-field="email" bindinput="handleDraftInput" />
    </block>
    <block wx:elif="{{tab === 'pathways'}}">
      <input placeholder="项目代码" value="{{draft.code}}" data-field="code" bindinput="handleDraftInput" />
      <input placeholder="中文项目名" value="{{draft.projectNameZh}}" data-field="projectNameZh" bindinput="handleDraftInput" />
      <input placeholder="英文项目名" value="{{draft.projectNameEn}}" data-field="projectNameEn" bindinput="handleDraftInput" />
      <textarea placeholder="中文目标" value="{{draft.objectiveZh}}" data-field="objectiveZh" bindinput="handleDraftInput" />
      <textarea placeholder="英文目标" value="{{draft.objectiveEn}}" data-field="objectiveEn" bindinput="handleDraftInput" />
    </block>
    <block wx:else>
      <input placeholder="角色编码，如 editor" value="{{draft.code}}" data-field="code" bindinput="handleDraftInput" />
      <input placeholder="角色名称" value="{{draft.name}}" data-field="name" bindinput="handleDraftInput" />
      <textarea placeholder="角色描述" value="{{draft.description}}" data-field="description" bindinput="handleDraftInput" />
      <view class="assign-box">
        <input placeholder="用户 openid" value="{{assignOpenid}}" data-field="openid" bindinput="handleAssignInput" />
        <input placeholder="角色编码" value="{{assignRoleCode}}" data-field="roleCode" bindinput="handleAssignInput" />
        <button bindtap="assignRole">绑定角色</button>
      </view>
    </block>
    <view class="button-row" style="margin-top: 16rpx;">
      <button type="primary" bindtap="saveDraft">保存</button>
      <button bindtap="resetDraft">清空</button>
    </view>
  </view>

  <view class="section">
    <view wx:if="{{loading}}" class="panel">加载中...</view>
    <view wx:for="{{records}}" wx:key="_id" class="admin-card">
      <view wx:if="{{tab === 'memberships'}}">
        <view class="record-title">{{item.nameZh}} / {{item.nameEn}}</view>
        <view class="muted">{{item.agendaNameZh}} {{item.titleOnAgenda}}</view>
      </view>
      <view wx:elif="{{tab === 'pathways'}}">
        <view class="record-title">{{item.code}} {{item.projectNameZh}}</view>
        <view class="muted">{{item.projectNameEn}}</view>
      </view>
      <view wx:else>
        <view class="record-title">{{item.code}} {{item.name}}</view>
        <view class="muted">{{item.description}}</view>
      </view>
      <view class="button-row">
        <button size="mini" data-index="{{index}}" bindtap="editRecord">编辑</button>
        <button size="mini" type="warn" data-index="{{index}}" bindtap="deleteRecord">删除</button>
      </view>
    </view>
  </view>
</view>
