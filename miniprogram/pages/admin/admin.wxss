.admin-card {
  background: #ffffff;
  border: 1rpx solid #dde3ea;
  border-radius: 8rpx;
  padding: 18rpx;
  margin-bottom: 16rpx;
}

.record-title {
  font-weight: 700;
  margin-bottom: 8rpx;
}

.assign-box {
  margin-top: 16rpx;
  padding: 14rpx;
  background: #f8fafc;
  border-radius: 8rpx;
}

.assign-box input,
.panel input,
.panel textarea {
  margin-bottom: 12rpx;
}
