.editor-page {
  padding-bottom: 180rpx;
}

.meeting-panel,
.agenda-section {
  margin-bottom: 20rpx;
}

.form-row {
  margin-top: 16rpx;
}

.form-row text {
  display: block;
  margin-bottom: 6rpx;
  color: #475569;
  font-size: 24rpx;
}

.inline-fields {
  display: flex;
  gap: 16rpx;
}

.inline-fields > view {
  flex: 1;
}

.section-header,
.item-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.section-header {
  min-height: 60rpx;
  padding-bottom: 12rpx;
  border-bottom: 1rpx solid #e2e8f0;
}

.drag-handle {
  color: #64748b;
  font-size: 34rpx;
  line-height: 1;
}

.section-title {
  flex: 1;
  font-weight: 700;
}

.section-title-en {
  display: block;
  margin-top: 4rpx;
  color: #94a3b8;
  font-size: 20rpx;
  font-weight: 400;
}

.section-actions,
.item-move-actions {
  display: flex;
  gap: 8rpx;
}

.agenda-item {
  margin-top: 16rpx;
  padding: 16rpx;
  background: #f8fafc;
  border: 1rpx solid #e2e8f0;
  border-radius: 8rpx;
}

.item-header {
  padding-bottom: 8rpx;
}

.item-time {
  min-width: 96rpx;
  color: #0f766e;
  font-weight: 700;
}

.item-order {
  flex: 1;
  color: #64748b;
}

.member-picker,
.picker-value {
  width: 100%;
  min-height: 72rpx;
  box-sizing: border-box;
}

.picker-value {
  padding: 18rpx 20rpx;
  background: #ffffff;
  border: 1rpx solid #cbd5e1;
  border-radius: 8rpx;
  color: #1f2937;
}

.speech-box {
  margin-top: 16rpx;
  padding: 12rpx;
  background: #ffffff;
  border: 1rpx solid #e2e8f0;
  border-radius: 8rpx;
}

.item-move-actions {
  justify-content: flex-end;
  margin-top: 12rpx;
}

.add-item-button {
  width: 100%;
  margin-top: 16rpx;
}

.bottom-actions {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 10;
  display: flex;
  align-items: center;
  gap: 10rpx;
  padding: 14rpx 24rpx calc(14rpx + env(safe-area-inset-bottom));
  background: #ffffff;
  border-top: 1rpx solid #dbe3ea;
  box-shadow: 0 -4rpx 18rpx rgba(15, 23, 42, 0.08);
}

.bottom-actions > button {
  flex: 1;
  margin: 0;
  font-size: 24rpx;
}

.language-switch {
  display: flex;
  gap: 4rpx;
}

.language-switch button {
  margin: 0;
  padding: 0 10rpx;
}

.export-button {
  background: #16a34a;
  color: #ffffff;
}
