.home-page {
  padding-top: 36rpx;
}

.home-button {
  width: 100%;
  height: 104rpx;
  line-height: 104rpx;
  margin: 0 0 24rpx;
  border-radius: 12rpx;
  font-size: 36rpx;
  font-weight: 600;
}

.primary-button {
  color: #ffffff;
  background: #16a34a;
}

.secondary-button {
  color: #111827;
  background: #f3f4f6;
  border: 1rpx solid #cbd5e1;
}
