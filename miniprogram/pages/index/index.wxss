.status-row {
  display: flex;
  justify-content: space-between;
  gap: 16rpx;
  padding: 12rpx 0;
  border-bottom: 1rpx solid #edf1f5;
}

.status-row:last-child {
  border-bottom: 0;
}

.status-label {
  color: #697586;
  flex: 0 0 150rpx;
}

.status-value {
  color: #1f2933;
  flex: 1;
  text-align: right;
  word-break: break-all;
}
