.nav-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 12rpx;
  margin-top: 18rpx;
}

.nav-button {
  min-height: 84rpx;
  font-size: 26rpx;
}

.wide-button {
  margin-top: 16rpx;
}

.status-row {
  display: flex;
  justify-content: space-between;
  gap: 16rpx;
}

.status-label {
  color: #697586;
  flex: 0 0 150rpx;
}

.status-value {
  color: #1f2933;
  flex: 1;
  text-align: right;
  word-break: break-all;
}
