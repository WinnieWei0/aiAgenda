.parse-page {
  padding-top: 24rpx;
}

.parse-input {
  width: 100%;
  min-height: 520rpx;
  box-sizing: border-box;
  background: #ffffff;
  border: 1rpx solid #cbd5e1;
  border-radius: 10rpx;
  padding: 22rpx;
}

.parse-button,
.edit-button {
  width: 100%;
  margin-top: 24rpx;
  border-radius: 10rpx;
}

.parse-button {
  background: #16a34a;
}

.edit-button {
  color: #111827;
  background: #f3f4f6;
  border: 1rpx solid #cbd5e1;
}
