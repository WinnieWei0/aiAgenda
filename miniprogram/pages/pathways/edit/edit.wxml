<view class="page">
  <view class="section panel">
    <view class="title">{{isEdit ? '编辑路径' : '新增路径'}}</view>
    <view class="muted">保存后将写入 Pathways 数据表。</view>
  </view>

  <view class="section panel form-panel">
    <input placeholder="项目代码，如 L4P3" value="{{pathway.code}}" data-field="code" bindinput="handleInput" />
    <input placeholder="中文项目名" value="{{pathway.projectNameZh}}" data-field="projectNameZh" bindinput="handleInput" />
    <input placeholder="英文项目名" value="{{pathway.projectNameEn}}" data-field="projectNameEn" bindinput="handleInput" />
    <textarea placeholder="中文目标" value="{{pathway.objectiveZh}}" data-field="objectiveZh" bindinput="handleInput" />
    <textarea placeholder="英文目标" value="{{pathway.objectiveEn}}" data-field="objectiveEn" bindinput="handleInput" />
    <view class="button-row">
      <button type="primary" loading="{{saving}}" bindtap="savePathway">保存</button>
      <button bindtap="cancelEdit">取消</button>
    </view>
  </view>
</view>
