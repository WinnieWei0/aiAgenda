<view class="page">
  <view class="section panel">
    <view class="title">路径列表</view>
    <view class="muted">维护 Pathways 项目，用于备稿项目描述。</view>
    <input placeholder="搜索项目代码、中文名、英文名" value="{{keyword}}" bindinput="handleKeywordInput" />
    <view class="button-row actions">
      <button type="primary" bindtap="openCreate">新增路径</button>
      <button loading="{{loading}}" bindtap="refreshRecords">刷新</button>
    </view>
  </view>

  <view class="section">
    <view wx:if="{{loading}}" class="panel">加载中...</view>
    <view wx:elif="{{!filteredRecords.length}}" class="panel muted">暂无路径数据</view>
    <view wx:for="{{filteredRecords}}" wx:key="_id" class="record-card">
      <view class="record-title">{{item.code}} {{item.fullLabelZh || '未命名项目'}}</view>
      <view class="muted">{{item.fullLabelEn}}</view>
      <view class="muted">{{item.objectiveZh}}</view>
      <view class="button-row card-actions">
        <button size="mini" data-id="{{item._id}}" bindtap="editRecord">编辑路径</button>
        <button size="mini" type="warn" data-id="{{item._id}}" data-name="{{item.code || item.fullLabelZh}}" bindtap="confirmDelete">删除</button>
      </view>
    </view>
  </view>
</view>
