.preview-page { padding-bottom: 120rpx; background: #e5e7eb; }
.paper-scroll { width: 100%; white-space: nowrap; }
.paper { box-sizing: border-box; width: 1120rpx; min-height: 1584rpx; margin: 24rpx; padding: 28rpx; border: 1rpx solid #111827; background: #ffffff; color: #111827; white-space: normal; box-shadow: 0 8rpx 24rpx rgba(15,23,42,.12); }
.brand-header { position: relative; padding: 14rpx 170rpx 22rpx; text-align: center; }
.brand-title { font-family: serif; font-size: 34rpx; font-weight: 700; }
.brand-subtitle { margin-top: 10rpx; font-family: serif; font-size: 28rpx; font-weight: 700; }
.charter { position: absolute; top: 12rpx; right: 0; width: 160rpx; font-size: 15rpx; white-space: pre-line; text-align: right; }
.info-strip { display: grid; grid-template-columns: 110rpx 1fr 1.35fr 1.35fr 1fr; gap: 10rpx; align-items: stretch; }
.club-logo { width: 108rpx; height: 108rpx; align-self: center; }
.info-card { min-height: 100rpx; padding: 14rpx; border: 1rpx solid #111827; border-radius: 18rpx; background: #62c4ee; font-size: 15rpx; white-space: pre-line; }
.info-title { display: block; font-weight: 700; }
.mission { padding: 10rpx 80rpx; text-align: center; font-family: serif; font-size: 16rpx; }
.mission text { display: block; }
.mission-en { font-weight: 700; }
.meeting-meta { display: grid; grid-template-columns: 1fr 1fr 2fr; padding: 4rpx 10rpx; font-family: serif; font-size: 17rpx; font-weight: 700; }
.page-one-body { display: grid; grid-template-columns: 76% 24%; border-top: 1rpx solid #111827; border-left: 1rpx solid #111827; }
.agenda-table { min-width: 0; }
.table-row { display: grid; grid-template-columns: 72rpx minmax(0,1fr) 74rpx 180rpx 120rpx; min-height: 26rpx; font-family: serif; font-size: 17rpx; }
.table-row > text, .title-cell { padding: 3rpx 5rpx; }
.table-head { min-height: 30rpx; border-bottom: 1rpx solid #d7dde5; background: #9bdcf6; font-weight: 700; text-align: center; }
.section-start-row { border-top: 1rpx solid #d7dde5; }
.club-cell { border-right: 1rpx solid #111827; }
.facilitator-head { grid-column: 1 / 3; }
.group-row { font-weight: 700; }
.note-row { background: #d1d5db; font-style: italic; }
.project-line, .objective-line { display: block; margin-top: 4rpx; font-size: 14rpx; font-weight: 400; }
.objective-line { line-height: 1.25; }
.duration-cell { text-align: right; }
.sidebar { border-right: 1rpx solid #111827; border-left: 0; font-family: serif; }
.side-title { padding: 7rpx; border-bottom: 1rpx solid #111827; background: #9bdcf6; font-size: 18rpx; font-weight: 700; text-align: center; }
.winner { display: flex; justify-content: space-between; padding: 18rpx 10rpx; font-size: 16rpx; }
.side-copy { padding: 14rpx; font-size: 16rpx; line-height: 1.4; }
.side-copy.centered { text-align: center; }
.side-qr { display: block; width: 126rpx; height: 126rpx; margin: 22rpx auto 4rpx; }
.qr-label { display: block; text-align: center; font-size: 16rpx; }
.timing-title { margin-top: 26rpx; font-family: serif; font-size: 18rpx; font-weight: 700; text-align: center; }
.timing-table { width: 84%; margin: 0 auto; }
.timing-row { display: grid; grid-template-columns: 1.35fr repeat(4,1fr); }
.timing-cell { padding: 5rpx; background: #e5e7eb; font-size: 16rpx; text-align: center; }
.timing-1 { background: #b8f5c0; }.timing-2 { background: #fff58a; }.timing-3 { background: #ff7777; }.timing-4 { background: #b5b5b5; }
.page-two { position: relative; }
.page-two-grid { display: grid; grid-template-columns: 35% 65%; min-height: 1450rpx; border: 1rpx solid #111827; }
.notes-column { border-right: 1rpx solid #111827; }
.cyan-title, .gray-title { padding: 8rpx; border-bottom: 1rpx solid #111827; background: #c9fbff; font-family: serif; font-size: 20rpx; font-weight: 700; text-align: center; }
.gray-title { background: #d1d5db; font-size: 17rpx; }
.updates-space { height: 64rpx; border-bottom: 1rpx solid #111827; }
.education-block { display: grid; grid-template-columns: 42% 58%; height: 200rpx; align-items: center; }
.education-block image { width: 100%; height: 180rpx; }
.pathway-list text { display: block; padding-left: 18rpx; font-size: 17rpx; line-height: 1.55; }
.goal { padding: 7rpx; border-top: 1rpx solid #111827; border-bottom: 1rpx solid #111827; background: #e5e1f0; font-weight: 700; text-align: center; }
.two-columns { display: grid; grid-template-columns: 1fr 1fr; border-bottom: 1rpx solid #111827; }
.two-columns > view:first-child { border-right: 1rpx solid #111827; }
.two-columns text { display: block; padding: 4rpx 14rpx; font-size: 16rpx; text-align: center; }
.two-columns.tall { min-height: 300rpx; }
.joining { padding: 18rpx !important; white-space: pre-line; text-align: left !important; line-height: 1.5; }
.officer-head, .officer-row { display: grid; grid-template-columns: 1.7fr 1fr 1fr; min-height: 34rpx; border-bottom: 1rpx solid #111827; font-size: 15rpx; }
.officer-head { background: #e2e8f0; text-align: center; }
.officer-head text, .officer-row text { padding: 6rpx; }
.officer-row:nth-child(even) { background: #d7ffff; }
.resources { position: absolute; right: 28rpx; bottom: 34rpx; left: 28rpx; font-size: 14rpx; text-align: center; }
.export-bar { position: fixed; right: 0; bottom: 0; left: 0; z-index: 5; padding: 18rpx 28rpx calc(18rpx + env(safe-area-inset-bottom)); border-top: 1rpx solid #cbd5e1; background: #ffffff; }
.export-bar button { width: 100%; }
.loading { padding: 120rpx 0; color: #64748b; text-align: center; }
